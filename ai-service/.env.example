# Service Configuration
NODE_ENV=development
AI_SERVICE_PORT=3005

# --- Database Connections ---
# This service needs read-only access to the databases of the other services.

# Core OpenEMIS DB (for student names, etc.)
CORE_DB_HOST=127.0.0.1
CORE_DB_USER=root
CORE_DB_PASSWORD=password
CORE_DB_NAME=openemis_core
CORE_DB_PORT=3306

# Attendance Service DB
ATTENDANCE_DB_HOST=127.0.0.1
ATTENDANCE_DB_USER=attendance_user
ATTENDANCE_DB_PASSWORD=password
ATTENDANCE_DB_NAME=openemis_attendance
ATTENDANCE_DB_PORT=3306

# Exam Service DB
EXAM_DB_HOST=127.0.0.1
EXAM_DB_USER=exam_user
EXAM_DB_PASSWORD=password
EXAM_DB_NAME=openemis_exams
EXAM_DB_PORT=3306

# --- At-Risk Analysis Parameters ---
# Adjust these thresholds to define what "at-risk" means.
EXAM_SCORE_THRESHOLD=50.0
ATTENDANCE_ABSENCE_THRESHOLD=5

# --- Logging Configuration ---
LOG_LEVEL=info
