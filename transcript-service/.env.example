# Server Configuration
PORT=3000

# Core System Connection Mode
# Set to 'DB' for direct database connection or 'API' for REST API connection
CONNECTION_MODE=DB

# Core System Database Connection (if CONNECTION_MODE is 'DB')
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=core_education_system

# Core System API Configuration (if CONNECTION_MODE is 'API')
CORE_API_BASE_URL=http://localhost/api
CORE_API_KEY=your-secret-api-key

# Logging Configuration
LOG_LEVEL=info
