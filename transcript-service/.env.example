# Service Configuration
NODE_ENV=development
TRANSCRIPT_SERVICE_PORT=3001

# Core System Connection Mode
# Set to 'db' to connect directly to the core database
# Set to 'api' to connect to the core system's API
CORE_DATA_MODE=api

# --- Database Configuration (used if CORE_DATA_MODE is 'db') ---
CORE_DB_HOST=127.0.0.1
CORE_DB_USER=root
CORE_DB_PASSWORD=password
CORE_DB_NAME=openemis_core
CORE_DB_PORT=3306

# --- API Configuration (used if CORE_DATA_MODE is 'api') ---
CORE_API_BASE_URL=http://localhost/openemis-core/api/
CORE_API_KEY=your_secret_api_key

# --- Logging Configuration ---
LOG_LEVEL=info
