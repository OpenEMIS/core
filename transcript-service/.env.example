#--------------------------------------------------------------------------
# Transcript Service Environment Configuration
#
# - Copy this file to .env in the root of the project.
# - Fill in the values for your environment.
# - This .env file should NOT be committed to version control.
#--------------------------------------------------------------------------

# --- Server Settings ---
PORT=3000

# --- Core System Connection ---
# Defines the method to fetch data from the core system.
# Options: 'DB' for direct database access, 'API' for REST API calls.
CONNECTION_MODE=DB

# --- Database Connection Settings (used if CONNECTION_MODE is 'DB') ---
CORE_DB_HOST=127.0.0.1
CORE_DB_USER=your_readonly_user
CORE_DB_PASSWORD=your_secret_password
CORE_DB_NAME=core_education_db_name

# --- REST API Connection Settings (used if CONNECTION_MODE is 'API') ---
CORE_API_URL=http://your-core-system.com/api
CORE_API_KEY=your-secret-api-key-for-auth

# --- Logging and Output ---
# The level of detail for logs (e.g., 'error', 'warn', 'info', 'http', 'debug')
LOG_LEVEL=info

# The directory where generated logs and other output files will be stored.
# This path is relative to the project root.
OUTPUT_DIR=./output
