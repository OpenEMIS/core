{
    "name": "korditpteltd/openemis-phpoe",
    "description": "KORDIT OpenEMIS CORE",
    "homepage": "https://demo.openemis.org/core",
    "type": "project",
    "license": "GPL-2.0",
    "require": {
        "php": ">=7.4",
        "cakephp/cakephp": "4.4.16",
        "mobiledetect/mobiledetectlib": "2.*",
        "korditpteltd/kd-cakephp-webhooks": "^1.0",
        "mk-j/php_xlsxwriter": "^0.32",
        "phpoffice/phpspreadsheet": "^1.3",
        "admad/cakephp-jwt-auth": "3.0.0",
        "mpdf/mpdf": "^8.1",
        "korditpteltd/iksso-cakephp-sso": "*",
        "korditpteltd/ikpge-cakephp-page": "*",
        "korditpteltd/ikrst-cakephp-restful": "*"
    },
    "require-dev": {
        "psy/psysh": "@stable",
        "phpunit/phpunit": "*",
        "cakephp/plugin-installer": "*",
        "cakephp/bake": "^2.6",
        "cakephp/migrations": "^3.2"
    },
    "suggest": {
        "phpunit/phpunit": "Allows automated tests to be run without system-wide install.",
        "cakephp/cakephp-codesniffer": "Allows to check the code against the coding standards used in CakePHP."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src",
            "Migrations\\": "Migrations",
            "User\\": "plugins/User/src/",
            "OpenEmis\\": "plugins/OpenEmis/src/",
            "ControllerAction\\": "./plugins/ControllerAction/src",
            "Angular\\": "./plugins/Angular/src",
            "Localization\\": "plugins/Localization/src/",
            "Area\\": "plugins/Area/src/",
            "Alert\\": "plugins/Alert/src/",
            "AcademicPeriod\\": "plugins/AcademicPeriod/src/",
            "Directory\\": "plugins/Directory/src/",
            "FieldOption\\": "plugins/FieldOption/src/",
            "Institution\\": "plugins/Institution/src/",
            "Student\\": "plugins/Student/src/",
            "Staff\\": "plugins/Staff/src/",
            "Education\\": "plugins/Education/src/",
            "Assessment\\": "plugins/Assessment/src/",
            "Textbook\\": "plugins/Textbook/src/",
            "Security\\": "plugins/Security/src/",
            "Survey\\": "plugins/Survey/src/",
            "Rest\\": "plugins/Rest/src/",
            "Rubric\\": "plugins/Rubric/src/",
            "Workflow\\": "plugins/Workflow/src/",
            "CustomField\\": "plugins/CustomField/src/",
            "Risk\\": "plugins/Risk/src/",
            "InstitutionCustomField\\": "plugins/InstitutionCustomField/src/",
            "StudentCustomField\\": "plugins/StudentCustomField/src/",
            "StaffCustomField\\": "plugins/StaffCustomField/src/",
            "Infrastructure\\": "plugins/Infrastructure/src/",
            "Error\\": "plugins/Error/src/",
            "Import\\": "plugins/Import/src/",
            "API\\": "plugins/API/src/",
            "Log\\": "plugins/Log/src/",
            "Training\\": "plugins/Training/src/",
            "Map\\": "plugins/Map/src/",
            "Health\\": "plugins/Health/src/",
            "Cache\\": "plugins/Cache/src/",
            "Restful\\": "plugins/Restful/src/",
            "SSO\\": "plugins/SSO/src/",
            "System\\": "plugins/System/src/",
            "System\\View\\Helper\\": "/View/Helper/",
            "InstitutionRepeater\\": "plugins/InstitutionRepeater/src/",
            "Examination\\": "plugins/Examination/src/",
            "Configuration\\": "plugins/Configuration/src/",
            "CustomExcel\\": "plugins/CustomExcel/src/",
            "Competency\\": "plugins/Competency/src/",
            "ReportCard\\": "plugins/ReportCard/src/",
            "Profile\\": "plugins/Profile/src/",
            "Transport\\": "plugins/Transport/src/",
            "Installer\\": "plugins/Installer/src/",
            "Quality\\": "plugins/Quality/src/",
            "Cases\\": "plugins/Cases/src/",
            "Counselling\\": "plugins/Counselling/src/",
            "Outcome\\": "plugins/Outcome/src/",
            "Theme\\": "plugins/Theme/src/",
            "StaffAppraisal\\": "plugins/StaffAppraisal/src/",
            "Scholarship\\": "plugins/Scholarship/src/",
            "Attendance\\": "plugins/Attendance/src/",
            "Guardian\\": "plugins/Guardian/src/",
            "Email\\": "plugins/Email/src/",
            "SpecialNeeds\\": "plugins/SpecialNeeds/src/",
            "MoodleApi\\": "plugins/MoodleApi/src/",
            "Historical\\": "plugins/Historical/src/",
            "Schedule\\": "plugins/Schedule/src/",
            "ProfileTemplate\\": "plugins/ProfileTemplate/src/",
            "Meal\\": "plugins/Meal/src/",
            "GuardianNav\\": "plugins/GuardianNav/src/",
            "OAuth\\": "plugins/OAuth/src/",
            "Archive\\": "plugins/Archive/src/",
            "Manuals\\": "./plugins/Manuals/src",
            "Report\\": "./plugins/Report/src",
            "KORDITPTELTD\\IKSSO-CAKEPHP-SSO\\": "./vendor/korditpteltd/iksso-cakephp-sso/src",
            "Gpa\\": "./plugins/Gpa/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests",
            "Cake\\Test\\": "./vendor/cakephp/cakephp/tests",
            "ControllerAction\\Test\\": "./plugins/ControllerAction/tests",
            "OAuth\\Test\\": "./plugins/OAuth/tests",
            "Archive\\Test\\": "./plugins/Archive/tests",
            "KORDITPTELTD\\IKPGE-CAKEPHP-PAGE\\": "./vendor/korditpteltd/ikpge-cakephp-page/src",
            "KORDITPTELTD\\IKSSO-CAKEPHP-SSO\\": "./vendor/korditpteltd/iksso-cakephp-sso/src"
        }
    },
    "scripts": {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall",
        "check": [
            "@test",
            "@cs-check"
        ],
        "cs-check": "phpcs --colors -p --standard=vendor/cakephp/cakephp-codesniffer/CakePHP ./src ./tests",
        "cs-fix": "phpcbf --colors --standard=vendor/cakephp/cakephp-codesniffer/CakePHP ./src ./tests",
        "test": "phpunit --colors=always",
        "update-except-core": [
            "composer update --with-dependencies --no-update cakephp/cakephp/src korditpteltd/kd-cakephp-webhooks korditpteltd/ikrst-cakephp-restful"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true
        }
    }
}
