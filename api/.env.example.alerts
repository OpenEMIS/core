# ============================================
# POCOR-9509: Asynchronous Alerts Queue
# ============================================
# Add these variables to your main .env file

# Maximum number of retry attempts before marking alert as permanently failed
ALERTS_MAX_RETRIES=3

# ============================================
# Twilio SMS Configuration
# ============================================
# Set TWILIO_ENABLED=true to enable SMS sending
# Get credentials from https://www.twilio.com/console

TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================
# Environment-Specific Recipient Filtering
# ============================================
# In non-production environments (UAT, DEV, LOCAL),
# alerts will ONLY be sent to these whitelisted recipients.
# This prevents accidental sending to real users during testing.
#
# Format: Comma-separated list (no spaces)
# Leave empty to send to all recipients in that environment

# Email whitelist for non-production
ALERTS_TEST_EMAILS=developer@example.com,tester@example.com

# Phone whitelist for non-production (E.164 format with country code)
ALERTS_TEST_PHONES=+12345678901,+10987654321

# ============================================
# Example Production Settings
# ============================================
# In production, leave test recipients empty or comment out:
# ALERTS_TEST_EMAILS=
# ALERTS_TEST_PHONES=
