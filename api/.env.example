APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
# POCOR-9509: SMTP connection timeout in seconds. Prevents PHP-FPM workers from hanging
# indefinitely when the mail server is unreachable. Set higher if your SMTP is slow.
MAIL_TIMEOUT=30

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# -------------------------------------------------------------------------
# POCOR-9509: Alert Scheduler Configuration
# -------------------------------------------------------------------------

# Timezone fallback used only when the database is unavailable (e.g. during migrations).
# At runtime the timezone is automatically read from config_items.code='time_zone' in the DB,
# so this value is overridden by whatever the admin has set in the System > Configuration UI.
# APP_TIMEZONE=UTC

# Maximum number of alert_queue rows processed per alerts:send run.
# ALERT_SEND_LIMIT=50  → process up to 50 per run (safe default)
# ALERT_SEND_LIMIT=0   → no limit — send all pending in one run (use with caution on large queues)
ALERT_SEND_LIMIT=50

# POCOR-9509: Concurrent background-alert worker cap per feature (e.g. AlertStudentAbsence).
# When the count of recent (last 5 min) running system_processes rows for a given feature
# reaches this limit, new triggers are skipped until existing workers complete.
# Tune against your php-fpm pm.max_children — rule of thumb: 25–50% of it.
# Default 5 ≈ half of typical pm.max_children=10.
ALERT_MAX_CONCURRENT=5
