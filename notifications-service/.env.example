# Service Configuration
NODE_ENV=development
NOTIFICATION_SERVICE_PORT=3004

# --- Notifications Service Database ---
# The database where this service will store its own notification logs.
NOTIFICATION_DB_HOST=127.0.0.1
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=password
NOTIFICATION_DB_NAME=openemis_notifications
NOTIFICATION_DB_PORT=3306

# --- Core System Connection ---
# For fetching user contact details (email, phone).
CORE_DATA_MODE=api
CORE_DB_HOST=127.0.0.1
CORE_DB_USER=root
CORE_DB_PASSWORD=password
CORE_DB_NAME=openemis_core
CORE_DB_PORT=3306
CORE_API_BASE_URL=http://localhost/openemis-core/api/
CORE_API_KEY=your_secret_api_key

# --- Email (Nodemailer) Configuration ---
# Example for a transactional email provider like SendGrid, Mailgun, or a simple SMTP server.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM="OpenEMIS Notifier" <no-reply@openemis.org>

# --- SMS (Twilio) Configuration ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15017122661

# --- Logging Configuration ---
LOG_LEVEL=info
