# Service Configuration
NODE_ENV=development
ATTENDANCE_SERVICE_PORT=3002

# --- Attendance Service Database ---
# The database where this service will store its own attendance records.
ATTENDANCE_DB_HOST=127.0.0.1
ATTENDANCE_DB_USER=attendance_user
ATTENDANCE_DB_PASSWORD=password
ATTENDANCE_DB_NAME=openemis_attendance
ATTENDANCE_DB_PORT=3306

# --- Core System Connection ---
# For validating students, classes, etc. before marking attendance.
# Set to 'db' to connect directly to the core database
# Set to 'api' to connect to the core system's API
CORE_DATA_MODE=api

# --- Core Database Configuration (used if CORE_DATA_MODE is 'db') ---
CORE_DB_HOST=127.0.0.1
CORE_DB_USER=root
CORE_DB_PASSWORD=password
CORE_DB_NAME=openemis_core
CORE_DB_PORT=3306

# --- Core API Configuration (used if CORE_DATA_MODE is 'api') ---
CORE_API_BASE_URL=http://localhost/openemis-core/api/
CORE_API_KEY=your_secret_api_key

# --- Logging Configuration ---
LOG_LEVEL=info
